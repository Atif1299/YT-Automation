# Development: copy to .env in the project folder (`npm start` loads it automatically).

GOOGLE_CLIENT_ID=

# Only if your OAuth client is type "Web application" (confidential). Desktop clients do not need this.
# Never commit real secrets. For installed .exe, put the same vars in:
#   Windows: %APPDATA%\yt-commenting\.env
# (electron-builder uses the package "name" for the folder — see app.getPath("userData").)

GOOGLE_CLIENT_SECRET=

# OAUTH_REDIRECT_PORT=53134
# OAUTH_CALLBACK_PATH=/oauth2callback

OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
